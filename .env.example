# Скопируй этот файл в .env и впиши настоящие значения.
# Файл .env в git НЕ попадает (он в .gitignore) — там лежат секреты.

# Токен бота — получи у @BotFather в Telegram (команда /newbot)
BOT_TOKEN=123456:ABC-YOUR-TOKEN-HERE

# ID администраторов (кому бот шлёт заявки в личку), через запятую.
# Свой ID можно узнать у бота @userinfobot
ADMIN_IDS=111111111,222222222

# Ссылка на гайд контактов на сайте (бот предлагает её как запасной вариант)
GUIDE_URL=https://www.podslushano.nl/contact-directory-netherlands/

# --- Искусственный интеллект (Claude) ---
# Ключ из консоли Anthropic: https://console.anthropic.com/ → API Keys.
# Без ключа бот работает на правилах (без «живого» ИИ).
ANTHROPIC_API_KEY=sk-ant-...
# Модель (по умолчанию быстрая и дешёвая Haiku). Менять не обязательно.
AI_MODEL=claude-haiku-4-5-20251001

# --- Стикеры ---
# Ссылка на ваш стикерпак, например https://t.me/addstickers/ВашПак
# Если задана — в меню появится кнопка «🎨 Наши стикеры» с этой ссылкой.
# Без неё кнопки просто нет.
STICKER_PACK_URL=

# --- Платное само-добавление (Mollie) ---
# Ключ Mollie (test_... для теста, live_... для боевого). Без него поток выключен.
MOLLIE_API_KEY=
# Цена и период размещения (по умолчанию 99 EUR на год)
LISTING_PRICE_MONTH=9.99
LISTING_PRICE_YEAR=99.00
LISTING_CURRENCY=EUR
# Публичный адрес для webhook оплаты. На Railway берётся автоматически из
# RAILWAY_PUBLIC_DOMAIN после «Generate Domain». Можно задать вручную:
# WEBHOOK_BASE_URL=https://ваш-домен.up.railway.app

# --- Защита от спама / лимиты ИИ ---
# Антифлуд: не больше FLOOD_LIMIT сообщений за FLOOD_WINDOW секунд
FLOOD_LIMIT=6
FLOOD_WINDOW=8
# Сколько ответов ИИ в день на пользователя (0 = без лимита)
AI_DAILY_LIMIT=40
